@page
@model Test

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lunch Check</title>
</head>
<body>

    <style>
        .container {
            text-align: center;
        }

        #dateBox {
            font-size: clamp(20px, 5vw, 32px);
            font-weight: bold;
            padding: 10px 15px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.2s;
            display: inline-block;

            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            border: 1px solid black;
        }

        #dateBox:hover {
            background-color: #f0f0f0;
            transform: scale(1.05);
            border: 1px solid black;
        }

        #meal {
            text-align: center;
            margin-top: 20px;

            max-width: 600px;
            margin: 20px auto;
        }

        .mealItem {
            margin: 3px;    
            cursor: pointer;
            transition: 0.2s;
            display: inline-block;
            padding: 10px 15px;
            border-radius: 8px;

            max-width: 90%; 
            border: 1px solid black;
        }

        .mealItem:hover {
            background-color: #f0f0f0;
            transform: scale(1.03);
            border: 1px solid black;
        }
        .allergyInfo {
            font-size: 14px;
            color: #666;
            background-color: #f5f5f5;
            border-radius: 8px;
            padding: 4px 8px;
            margin: 3px auto 3px auto;
            width: fit-content;

            word-break: keep-all;
            overflow-wrap: break-word;
        }

        @@media (max-width: 768px)
        {
            #dateBox
            {
                font-size: 24px;
            }

            .mealItem
            {
                display: block;
                width: 90%;
                margin: 8px auto;
            }

            .allergyInfo
            {
                width: 90%;
            }
        }
    </style>

    <div class="container">

        <div id="dateBox">
            <span id="currentDate">@Model.Days</span>
        </div>

        <input type="date" id="datePicker" style="opacity:0; position:absolute;" />

        <div id="meal"></div>

    </div>

    <script>
        // 알러지 정보
        const allergyMap = {
            "1": "난류",
            "2": "우유",
            "3": "메밀",
            "4": "땅콩",
            "5": "대두",
            "6": "밀",
            "7": "고등어",
            "8": "게",
            "9": "새우",
            "10": "돼지고기",
            "11": "복숭아",
            "12": "토마토",
            "13": "아황산류",
            "14": "호두",
            "15": "닭고기",
            "16": "쇠고기",
            "17": "오징어",
            "18": "조개류"
        };

        // 급식 렌더링
        function renderMeal(text) {

            const mealDiv = document.getElementById("meal");

            mealDiv.innerHTML = "";

            const lines = text.split("\n");

            lines.forEach(line => {

                if (line.trim() === "")
                    return;

                const div = document.createElement("div");

                div.className = "mealItem";

                // 괄호 안 숫자 찾기
                const match = line.match(/\((\d+(\.\d+)*)\)\s*$/);

                let allergyText = "알러지 정보 없음";

                if (match) {

                    const nums = match[1].split(".");

                    allergyText = nums
                        .map(n => allergyMap[n] || n)
                        .join(", ");
                }

                div.innerText = line;

                div.onclick = () => {

                    // 이미 열려있으면 닫기
                    if (div.nextElementSibling &&
                        div.nextElementSibling.className === "allergyInfo")
                    {
                        div.nextElementSibling.remove();
                        return;
                    }

                    // 알러지 정보 div 생성
                    const info = document.createElement("div");

                    info.className = "allergyInfo";

                    info.innerText = "알러지 정보 : " + allergyText;

                    div.after(info);
                };

                mealDiv.appendChild(div);

                mealDiv.appendChild(document.createElement("br"));
            });
        }

        // 초기 급식 표시
        renderMeal(`@Html.Raw(Model.Meal1?.Replace("\n", "\\n"))`);

        // 달력 열기
        document.getElementById("dateBox").onclick = () => {
            document.getElementById("datePicker").showPicker();
        };

        // 날짜 선택 시
        document.getElementById("datePicker").onchange = async (e) => {

            const raw = e.target.value;

            const date = raw.replaceAll("-", "");

            // 날짜 객체
            const d = new Date(raw);

            // 요일 배열
            const days = [
                "일요일",
                "월요일",
                "화요일",
                "수요일",
                "목요일",
                "금요일",
                "토요일"
            ];

            const dayName = days[d.getDay()];

            const formatted = `${raw} ${dayName}`;

            // 서버 요청
            const response = await fetch(`?handler=Meal&date=${date}`);

            const data = await response.text();

            // 급식 출력
            renderMeal(data);

            // 날짜 변경
            document.getElementById("currentDate").innerText = formatted;
        };

    </script>

</body>
</html>